# AI Research Orchestrator - Environment Variables

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Search Configuration
SERPAPI_KEY=your_serpapi_key_here  # Optional: for SerpAPI
TAVILY_API_KEY=your_tavily_api_key_here  # Optional: for Tavily search

# Docker Configuration (for code execution)
DOCKER_HOST=unix:///var/run/docker.sock  # Linux/Mac
# DOCKER_HOST=npipe:////./pipe/docker_engine  # Windows

# Orchestrator Settings
MAX_RETRIES=3
RETRY_DELAY=2
MAX_CONCURRENT_AGENTS=5
TIMEOUT_SECONDS=120

# Logging
LOG_LEVEL=INFO
